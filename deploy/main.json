      ]
    },
    {
      "condition": "[and(parameters('enablePersistentStorage'), parameters('enableVnet'))]",
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2024-05-01",
      "name": "[format('{0}-storage-pe', parameters('baseName'))]",
