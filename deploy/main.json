      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks/subnets', format('{0}-vnet', parameters('baseName')), 'infrastructure')]"
      ]
    },
    {
      "condition": "[parameters('enablePersistentStorage')]",
      "type": "Microsoft.Storage/storageAccounts/fileServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', replace(format('{0}data', parameters('baseName')), '-', ''), 'default')]",
      "dependsOn": [
