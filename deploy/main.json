        },
        "vnetConfiguration": "[if(parameters('enableVnet'), createObject('infrastructureSubnetId', resourceId('Microsoft.Network/virtualNetworks/subnets', format('{0}-vnet', parameters('baseName')), 'infrastructure'), 'internal', false()), null())]",
        "workloadProfiles": [
          {
            "name": "Consumption",
            "workloadProfileType": "Consumption"
          }
        ]
